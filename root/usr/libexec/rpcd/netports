local json = require "luci.jsonc"
local fs   = require "nixio.fs"

local sysfs_net_root        = "/sys/class/net"
local netports_log_file     = "/tmp/netports-events.json"
local netports_state_file   = "/tmp/netports-state.json"
local netports_baseline_file= "/tmp/netports-baseline.json"

local function sysfs_net_read(ifname, file)
	local v = nil
	if fs.access(sysfs_net_root .. "/%s/%s" % {ifname, file}) then
		v = fs.readfile(sysfs_net_root .. "/%s/%s" % {ifname, file})
		if v then
			v = v:gsub("\n", "")
		end
	end
	return v or ''
end

local function sysfs_net_read_stats(ifname)
	return {
		tx_bytes   = tonumber(sysfs_net_read(ifname, "statistics/tx_bytes")) or 0,
		tx_packets = tonumber(sysfs_net_read(ifname, "statistics/tx_packets")) or 0,
		rx_bytes   = tonumber(sysfs_net_read(ifname, "statistics/rx_bytes")) or 0,
		rx_packets = tonumber(sysfs_net_read(ifname, "statistics/rx_packets")) or 0,
	}
end

local error_keys = {
	"rx_errors", "rx_crc_errors", "rx_frame_errors", "rx_fifo_errors",
	"rx_over_errors", "rx_dropped",
	"tx_errors", "tx_carrier_errors", "tx_aborted_errors", "tx_fifo_errors",
	"tx_dropped", "collisions"
}

local function sysfs_net_read_errors(ifname)
	local r = {}
	for _, k in ipairs(error_keys) do
		r[k] = tonumber(sysfs_net_read(ifname, "statistics/" .. k)) or 0
	end
	return r
end

local function subtract_errors(now_v, base_v)
	local r = {}
	for _, k in ipairs(error_keys) do
		local n = tonumber(now_v[k]) or 0
		local b = tonumber((base_v or {})[k]) or 0
		local d = n - b
		if d < 0 then d = n end -- counter wrap or interface re-init
		r[k] = d
	end
	return r
end

local function sysfs_net_read_bridge(ifname)
	local b = { }
	b["port"] = tonumber(sysfs_net_read(ifname, "brport/port_no")) or 0
	if b["port"] == 0 then return nil end
	local b_path = fs.readlink(sysfs_net_root .. "/%s/brport/bridge" % ifname)
	if b_path then
		b["ifname"] = fs.basename(b_path)
	end
	return b
end

local function type_autodetect(ifname)
	local matches = {
		copper = { "^eth%d+", "^en%l%d+%l%d+", "^sw%d+p%d+" },
		usb_rndis = { "^usb%d+" },
		usb_stick = { "^wwan%d+", "^ww%l%d+%l%d+" },
		ppp = { "^ppp%d+" },
		tunnel = { "^tun%d+", "^tap%d+", "^wg%d+" },
		wifi = { "^wlan%d+", "^wl%l%d+%l%d+" }
	}
	for t, m in pairs(matches) do
		for i in pairs(m) do
			if ifname:match(m[i]) then return t end
		end
	end
	return "copper"
end

local function table_copy(t)
	if t == nil then return nil end
	local u = { }
	for k, v in pairs(t) do u[k] = v end
	return setmetatable(u, getmetatable(t))
end

-- ---------------------------------------------------------------------------
-- Persistent helpers (all in /tmp = tmpfs, reset on reboot)
-- ---------------------------------------------------------------------------

local function read_json_file(path)
	local s = fs.readfile(path)
	if not s or s == "" then return {} end
	local ok, t = pcall(json.parse, s)
	if ok and type(t) == "table" then return t end
	return {}
end

local function write_json_file(path, data)
	pcall(fs.writefile, path, json.stringify(data))
end

local function append_event(ifname, ev, extra)
	local entry = { ts = os.time(), ["if"] = ifname, ev = ev, src = "poll" }
	if extra then
		for k, v in pairs(extra) do entry[k] = v end
	end
	local f = io.open(netports_log_file, "a")
	if f then
		f:write(json.stringify(entry) .. "\n")
		f:close()
	end
end

local function read_events()
	local events = {}
	local f = io.open(netports_log_file, "r")
	if not f then return events end
	for line in f:lines() do
		if line and #line > 0 then
			local ok, e = pcall(json.parse, line)
			if ok and type(e) == "table" then events[#events+1] = e end
		end
	end
	f:close()
	return events
end

local function calc_flap_stats(events, ifname, now)
	local stats = { count_5m=0, count_1h=0, count_24h=0, last_ts=0, last_ev="" }
	for _, e in ipairs(events) do
		if e["if"] == ifname then
			local ets = tonumber(e.ts) or 0
			local age = now - ets
			if age >= 0 and age <= 300   then stats.count_5m  = stats.count_5m  + 1 end
			if age >= 0 and age <= 3600  then stats.count_1h  = stats.count_1h  + 1 end
			if age >= 0 and age <= 86400 then stats.count_24h = stats.count_24h + 1 end
			if ets > stats.last_ts then
				stats.last_ts = ets
				stats.last_ev = e.ev or ""
			end
		end
	end
	return stats
end

local function rotate_log_if_needed()
	local size = fs.stat(netports_log_file, "size")
	if size and size > 256 * 1024 then
		local f = io.open(netports_log_file, "r")
		if f then
			f:seek("end", -65536)
			f:read("*l")
			local rest = f:read("*a") or ""
			f:close()
			pcall(fs.writefile, netports_log_file, rest)
		end
	end
end

-- ---------------------------------------------------------------------------

local methods = {
	getPortsInfo = {
		call = function(args)
			local util = require("luci.util")
			local uci  = require("luci.model.uci").cursor()
			local ntm  = require("luci.model.network").init()
			local fwm  = require("luci.model.firewall").init()
			local bit  = require("bit")

			local ports = { data = {}, count = 0 }
			local netlist = {}
			local brlist  = {}

			for _, net in ipairs(ntm:get_networks()) do
				local iface = net:get_interface()
				local wifiname = nil
				if iface ~= nil then
					if iface:type() == "wifi" then
						local wifinet = iface:get_wifinet()
						wifiname = wifinet:id()
					end
					local name   = iface:name()
					local fwzone = fwm:get_zone_by_network(net:name())
					local l = netlist
					if not net:is_alias() and iface:is_bridge() then
						l = brlist
					end
					l[name] = {}
					l[name]["netname"]  = net:name()
					l[name]["wifiname"] = wifiname
					if fwzone then
						l[name]["fwzone"]     = fwzone:name()
						l[name]["fwzone_sid"] = fwzone.sid
					end
				end
			end

			-- Edge-detection state and error baseline
			local state    = read_json_file(netports_state_file)
			local baseline = read_json_file(netports_baseline_file)
			local now      = os.time()

			uci:foreach("luci_netports", "port",
				function(section)
					if section["disable"] and (section["disable"] == "true"
						or tonumber(section["disable"]) == 1) then
						return true
					end
					if not fs.access("/sys/class/net/%s/ifindex" % section["ifname"]) then
						return true
					end

					local new_port = {}
					local ifname = section["ifname"]
					local ptype  = section["type"]

					local knowntypes = {
						"auto","copper","fixed","usb","usb_stick","usb_rndis",
						"usb_2g","usb_3g","usb_4g","usb_wifi","wifi","vpn",
						"tunnel","ppp","gprs","sfp"
					}
					if not util.contains(knowntypes, ptype) then ptype = "auto" end
					if     ptype == "auto"     then ptype = type_autodetect(ifname)
					elseif ptype == "usb"      then ptype = "usb_rndis"
					elseif ptype == "usb_2g" or ptype == "usb_3g" or ptype == "usb_4g" then
						ptype = "usb_stick"
					elseif ptype == "usb_wifi" then ptype = "wifi"
					elseif ptype == "vpn"      then ptype = "tunnel"
					end

					new_port["ifname"]  = ifname
					new_port["type"]    = ptype
					new_port["name"]    = section["name"]
					if not new_port["name"] or new_port["name"] == "" then
						new_port["name"] = ifname
					end
					new_port["hwaddr"]    = sysfs_net_read(ifname, "address")
					new_port["carrier"]   = tonumber(sysfs_net_read(ifname, "carrier")) or 0
					new_port["operstate"] = sysfs_net_read(ifname, "operstate")

					local flags = sysfs_net_read(ifname, "flags")
					if bit.band(tonumber(flags), 1) == 1 then
						new_port["adminstate"] = "up"
					else
						new_port["adminstate"] = "down"
					end

					if new_port["carrier"] > 0 then
						new_port["duplex"] = sysfs_net_read(ifname, "duplex")
						new_port["speed"]  = tonumber(sysfs_net_read(ifname, "speed")) or 0
						if new_port["speed"] < 0 then new_port["speed"] = 0 end
					end

					new_port["stats"]      = sysfs_net_read_stats(ifname)

					-- Errors with optional baseline subtraction (so "Reset" works)
					local errors_raw = sysfs_net_read_errors(ifname)
					new_port["errors_raw"] = errors_raw
					if baseline[ifname] then
						new_port["errors"] = subtract_errors(errors_raw, baseline[ifname])
					else
						new_port["errors"] = errors_raw
					end

					new_port["bridge"] = sysfs_net_read_bridge(ifname)
					new_port["ntm"]    = table_copy(netlist[ifname])
					if new_port["bridge"] then
						new_port["ntm_bridge"] = table_copy(brlist[new_port["bridge"].ifname])
					end

					new_port["id"] = section[".name"]

					-- Edge-detection on carrier
					local prev = state[ifname]
					if prev ~= nil and prev ~= new_port["carrier"] then
						local ev = (new_port["carrier"] == 1) and "up" or "down"
						local extra = {}
						if ev == "up" and new_port["speed"] then
							extra.speed  = new_port["speed"]
							extra.duplex = new_port["duplex"]
						end
						append_event(ifname, ev, extra)
					end
					state[ifname] = new_port["carrier"]

					ports.data[#ports.data + 1] = new_port
					ports.count = ports.count + 1
				end
			)

			write_json_file(netports_state_file, state)
			rotate_log_if_needed()

			-- Reload events (incl. just-appended) and compute flap stats
			local events = read_events()
			for _, p in ipairs(ports.data) do
				p.flaps = calc_flap_stats(events, p.ifname, now)
			end

			-- Provide reset timestamp (so UI can show "Resetováno: <čas>")
			local meta = read_json_file(netports_baseline_file .. ".meta")
			ports.reset_ts = tonumber(meta.ts) or 0
			ports.now      = now

			return ports
		end
	},

	getPortEvents = {
		args = { ifname = "string", limit = 0 },
		call = function(args)
			local events = read_events()
			local filtered = {}
			local want = args.ifname
			if want == "" then want = nil end
			for _, e in ipairs(events) do
				if not want or e["if"] == want then
					filtered[#filtered+1] = e
				end
			end
			local lim = tonumber(args.limit) or 0
			if lim > 0 and #filtered > lim then
				local cut = {}
				for i = #filtered - lim + 1, #filtered do
					cut[#cut+1] = filtered[i]
				end
				filtered = cut
			end
			return { events = filtered, count = #filtered }
		end
	},

	resetStats = {
		args = { scope = "all" },
		call = function(args)
			local uci = require("luci.model.uci").cursor()
			local scope = args.scope or "all"
			local now = os.time()

			-- 1) Capture current errors as new baseline
			local baseline = {}
			uci:foreach("luci_netports", "port", function(s)
				local ifn = s["ifname"]
				if ifn and fs.access("/sys/class/net/" .. ifn .. "/ifindex") then
					baseline[ifn] = sysfs_net_read_errors(ifn)
				end
			end)
			write_json_file(netports_baseline_file, baseline)
			write_json_file(netports_baseline_file .. ".meta", { ts = now })

			-- 2) Clear flap event log + state
			pcall(fs.writefile, netports_log_file, "")
			pcall(fs.writefile, netports_state_file, "{}")

			return { ok = true, ts = now, scope = scope }
		end
	}
}

local function parseInput()
	local parse = json.new()
	local done, err
	while true do
		local chunk = io.read(4096)
		if not chunk then break
		elseif not done and not err then
			done, err = parse:parse(chunk)
		end
	end
	if not done then
		print(json.stringify({ error = err or "Incomplete input" }))
		os.exit(1)
	end
	return parse:get()
end

local function validateArgs(func, uargs)
	local method = methods[func]
	if not method then
		print(json.stringify({ error = "Method not found" })); os.exit(1)
	end
	if type(uargs) ~= "table" then
		print(json.stringify({ error = "Invalid arguments" })); os.exit(1)
	end
	uargs.ubus_rpc_session = nil
	local margs = method.args or {}
	for k, v in pairs(uargs) do
		if margs[k] == nil or
		   (v ~= nil and type(v) ~= type(margs[k])) then
			print(json.stringify({ error = "Invalid arguments" })); os.exit(1)
		end
	end
	return method
end

if arg[1] == "list" then
	local rv = {}
	for name, method in pairs(methods) do
		rv[name] = method.args or {}
	end
	print((json.stringify(rv):gsub(":%[%]", ":{}")))
elseif arg[1] == "call" then
	local args = parseInput()
	local method = validateArgs(arg[2], args)
	local ok, result = pcall(method.call, args)
	if not ok then
		syslog(tostring(result))
		print(json.stringify({ error = tostring(result) })); os.exit(1)
	end
	print((json.stringify(result):gsub("^%[%]$", "{}")))
	os.exit(result.code or 0)
end
