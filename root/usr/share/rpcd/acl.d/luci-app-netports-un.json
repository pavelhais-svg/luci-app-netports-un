{
	"luci-app-netports-un": {
		"description": "Grant access to network ports status information",
		"read": {
			"ubus": {
				"session": [ "access", "login" ],
				"service": [ "list" ],
				"netports": [ "getPortsInfo", "getPortEvents" ]
			},
			"uci": [ "luci_netports" ]
		},
		"write": {
			"ubus": {
				"netports": [ "resetStats" ]
			},
			"uci": [ "luci_netports" ]
		}
	}
}
